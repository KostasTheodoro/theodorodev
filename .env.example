# Resend API key for the contact form (server-only, never exposed to the client).
# The form is always visible; leave this unset locally to have submissions
# return a graceful "not wired up yet" response instead of actually sending mail.
RESEND_API_KEY=re_replace_with_your_key

# Sender address for outgoing contact-form emails. Must be a verified Resend sending domain.
CONTACT_FROM_EMAIL=contact@theodorodev.com

# Sender display name for outgoing contact-form emails.
CONTACT_FROM_NAME=TheodoroDev Website

# Inbox that receives contact-form submissions.
CONTACT_TO_EMAIL=kostas@theodorodev.com

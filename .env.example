# Resend API key for the contact form (server-only, never exposed to the client).
# The form is always visible; leave this unset locally to have submissions
# return a graceful "not wired up yet" response instead of actually sending mail.
RESEND_API_KEY=

# Optional. Sender address for outgoing contact-form emails.
# Defaults to Resend's sandbox sender (onboarding@resend.dev) until theodorodev.com is verified with Resend.
RESEND_FROM_EMAIL=

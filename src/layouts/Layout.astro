---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { Menu, X } from 'lucide-astro';
import Logo from '@/components/Logo.astro';
import SocialIcon from '@/components/SocialIcon.astro';
import ScrollToTopButton from '@/components/ScrollToTopButton.astro';
import PersonSchema from '@/components/PersonSchema.astro';
import { siteContact } from '@/lib/site';
import { useTranslations, getLangFromUrl, getLogicalPath } from '@/i18n/utils';

import '@/styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
	type?: 'website' | 'article';
}

const { title, description, image, type = 'website' } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const ogLocale = lang === 'el' ? 'el_GR' : 'en_US';
const ogLocaleAlternate = lang === 'el' ? 'en_US' : 'el_GR';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const ogPathname = Astro.url.pathname.replace(/\/$/, '');
const ogKey = ogPathname === '' ? '/home' : ogPathname === '/el' ? '/el/home' : ogPathname;
const ogImagePath = image ?? `/og${ogKey}.png`;
const ogImageURL = new URL(ogImagePath, Astro.site);

const logicalPath = getLogicalPath(Astro.url);
const enPath = getRelativeLocaleUrl('en', logicalPath);
const elPath = getRelativeLocaleUrl('el', logicalPath);
const enURL = new URL(enPath, Astro.site);
const elURL = new URL(elPath, Astro.site);
const switchPath = lang === 'en' ? elPath : enPath;
const switchLabel = lang === 'en' ? 'EL' : 'EN';

const homeHref = getRelativeLocaleUrl(lang, '');

const navLinks = [
	{ href: getRelativeLocaleUrl(lang, 'projects'), label: t('nav.projects') },
	{ href: getRelativeLocaleUrl(lang, 'about'), label: t('nav.about') },
	{ href: getRelativeLocaleUrl(lang, 'contact'), label: t('nav.contact') },
];
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="theme-color" content="#0b1b20" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content={type} />
		<meta property="og:site_name" content="Kostas Theodoropoulos" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:alt" content={title} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={ogLocaleAlternate} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />
		<meta name="twitter:image:alt" content={title} />

		<link rel="alternate" hreflang="en" href={enURL} />
		<link rel="alternate" hreflang="el" href={elURL} />
		<link rel="alternate" hreflang="x-default" href={enURL} />

		<PersonSchema />

		<Font cssVariable="--font-instrument-sans" preload />
		<Font cssVariable="--font-jetbrains-mono" />
		<ClientRouter />
		<script is:inline>
			(function () {
				const stored = localStorage.getItem('theme');
				const theme =
					stored === 'light' || stored === 'dark'
						? stored
						: matchMedia('(prefers-color-scheme: light)').matches
							? 'light'
							: 'dark';
				document.documentElement.dataset.theme = theme;
			})();

			document.addEventListener('astro:before-swap', (event) => {
				event.newDocument.documentElement.dataset.theme = document.documentElement.dataset.theme;
			});
		</script>
	</head>
	<body class="flex min-h-screen flex-col">
		<header class="sticky top-0 z-30 border-b border-border bg-bg">
			<nav class="mx-auto grid max-w-5xl grid-cols-[auto_1fr_auto] items-center gap-4 px-6 py-4 md:flex md:justify-between md:gap-6">
				<!-- vanilla JS toggle: zero-JS-by-default rule, matches theme-toggle pattern below -->
				<button
					id="mobile-menu-toggle"
					type="button"
					class="mobile-menu-toggle text-text hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg md:hidden"
					aria-expanded="false"
					aria-controls="mobile-menu-panel"
					aria-label="Open navigation menu"
				>
					<Menu class="icon-menu h-6 w-6" aria-hidden="true" />
					<X class="icon-close hidden h-6 w-6" aria-hidden="true" />
				</button>

				<a href={homeHref} class="flex items-center justify-self-center gap-2 font-mono text-sm text-text md:justify-self-auto">
					<Logo />
					theodorodev
				</a>

				<div class="flex items-center justify-self-end gap-4 text-sm sm:gap-6 md:justify-self-auto">
					{navLinks.map((link) => (
						<a href={link.href} class="hidden text-text hover:text-primary md:inline">{link.label}</a>
					))}
					<a href={switchPath} class="font-mono text-text-muted hover:text-primary" aria-label={t('switch.aria')}>{switchLabel}</a>
					<button
						id="theme-toggle"
						type="button"
						class="theme-toggle text-text hover:text-primary"
						aria-label="Toggle color theme"
					>
						<svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<circle cx="12" cy="12" r="4" />
							<path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
						</svg>
						<svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
						</svg>
					</button>
				</div>
			</nav>

			<div
				id="mobile-menu-panel"
				class="absolute inset-x-0 top-full z-20 hidden flex-col gap-1 border-t border-border bg-bg-card px-6 py-4 text-sm md:hidden"
			>
				{navLinks.map((link) => (
					<a
						href={link.href}
						class="rounded px-3 py-3 text-text hover:bg-bg hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
						>{link.label}</a
					>
				))}
			</div>
		</header>

		<main class="flex-1">
			<slot />
		</main>

		<footer class="border-t border-border">
			<div class="mx-auto flex max-w-5xl flex-col items-center gap-4 px-6 py-8 text-sm text-text-muted lg:grid lg:grid-cols-[auto_1fr_auto] lg:items-center lg:gap-6">
				<p class="lg:justify-self-start lg:whitespace-nowrap">&copy; {new Date().getFullYear()} Kostas Theodoropoulos &middot; {t('footer.rights')}</p>
				<div class="flex flex-wrap items-center justify-center gap-4 lg:justify-self-center">
					<a
						href={siteContact.whatsappHref}
						class="flex items-center gap-2 hover:text-primary"
						rel="noopener"
						target="_blank"
					>
						<SocialIcon name="whatsapp" />
						<span>WhatsApp</span>
					</a>
					<a
						href={siteContact.githubHref}
						class="flex items-center gap-2 hover:text-primary"
						rel="noopener"
						target="_blank"
					>
						<SocialIcon name="github" />
						<span>GitHub</span>
					</a>
					<a
						href={siteContact.linkedinHref}
						class="flex items-center gap-2 hover:text-primary"
						rel="noopener"
						target="_blank"
					>
						<SocialIcon name="linkedin" />
						<span>LinkedIn</span>
					</a>
				</div>
				<p class="lg:justify-self-end lg:whitespace-nowrap">{t('footer.builtWith')} <span class="text-primary">&hearts;</span> &middot; Astro + React + Tailwind</p>
			</div>
		</footer>

		<ScrollToTopButton />

		<script is:inline>
			document.addEventListener('astro:page-load', () => {
				const toggle = document.getElementById('theme-toggle');
				toggle?.addEventListener('click', () => {
					const root = document.documentElement;
					const next = root.dataset.theme === 'light' ? 'dark' : 'light';
					root.dataset.theme = next;
					localStorage.setItem('theme', next);
				});
			});
		</script>

		<script is:inline>
			document.addEventListener('astro:page-load', () => {
				const toggle = document.getElementById('mobile-menu-toggle');
				const panel = document.getElementById('mobile-menu-panel');
				if (!toggle || !panel) return;

				const menuIcon = toggle.querySelector('.icon-menu');
				const closeIcon = toggle.querySelector('.icon-close');

				const isOpen = () => toggle.getAttribute('aria-expanded') === 'true';

				function openMenu() {
					if (isOpen()) return;
					panel.classList.remove('hidden');
					panel.classList.add('flex');
					requestAnimationFrame(() => panel.classList.add('is-open'));
					toggle.setAttribute('aria-expanded', 'true');
					toggle.setAttribute('aria-label', 'Close navigation menu');
					menuIcon?.classList.add('hidden');
					closeIcon?.classList.remove('hidden');
				}

				function closeMenu({ focusToggle = false } = {}) {
					if (!isOpen()) return;
					toggle.setAttribute('aria-expanded', 'false');
					toggle.setAttribute('aria-label', 'Open navigation menu');
					menuIcon?.classList.remove('hidden');
					closeIcon?.classList.add('hidden');
					panel.classList.remove('is-open');

					const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
					const hide = () => {
						panel.classList.add('hidden');
						panel.classList.remove('flex');
					};
					if (prefersReducedMotion) {
						hide();
					} else {
						panel.addEventListener('transitionend', hide, { once: true });
					}
					if (focusToggle) toggle.focus();
				}

				function onKeydown(event) {
					if (isOpen() && event.key === 'Escape') closeMenu({ focusToggle: true });
				}

				function onClickOutside(event) {
					if (isOpen() && !panel.contains(event.target) && !toggle.contains(event.target)) {
						closeMenu();
					}
				}

				toggle.addEventListener('click', () => (isOpen() ? closeMenu({ focusToggle: true }) : openMenu()));
				panel.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => closeMenu()));

				// document persists across Astro view transitions (only <body> children are
				// replaced), so these listeners must be torn down before each swap or they leak.
				document.addEventListener('keydown', onKeydown);
				document.addEventListener('click', onClickOutside);
				document.addEventListener(
					'astro:before-swap',
					() => {
						document.removeEventListener('keydown', onKeydown);
						document.removeEventListener('click', onClickOutside);
					},
					{ once: true },
				);
			});
		</script>
	</body>
</html>

<style>
	.theme-toggle .icon-moon {
		display: none;
	}

	[data-theme='light'] .theme-toggle .icon-sun {
		display: none;
	}

	[data-theme='light'] .theme-toggle .icon-moon {
		display: block;
	}

	@media (prefers-reduced-motion: no-preference) {
		a,
		.theme-toggle {
			transition: color 200ms ease;
		}
	}

	#mobile-menu-panel {
		opacity: 0;
		transform: translateY(-0.5rem);
	}

	#mobile-menu-panel.is-open {
		opacity: 1;
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: no-preference) {
		#mobile-menu-panel {
			transition:
				opacity 150ms ease,
				transform 150ms ease;
		}
	}
</style>

---
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getProjects } from '@/lib/content';

const projects = await getProjects('en');
---

<Layout title="Projects — theodorodev">
	<section class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-24">
		<h1 class="text-4xl text-text sm:text-5xl">
			{/* TODO: review copy */}
			Projects
		</h1>
		<div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
			{projects.map((project) => <ProjectCard project={project} showYear />)}
		</div>
	</section>
</Layout>

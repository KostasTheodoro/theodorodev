---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import PersonSchema from '@/components/PersonSchema.astro';
import { getFeaturedProjects } from '@/lib/content';

const featured = await getFeaturedProjects('en');
---

<Layout
	title="theodorodev — web developer, Athens"
	description="I design and build fast, focused websites for small businesses and teams who need results, not bloat."
>
	<PersonSchema />
	<Hero />

	<section class="section-alt relative">
		<div class="section-blend section-blend-top" aria-hidden="true"></div>
		<div class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-16">
			<h2 class="text-2xl text-text">My recent projects</h2>
			<div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
				{featured.map((project) => <ProjectCard project={project} />)}
			</div>
		</div>
	</section>

	<section class="relative">
		<div class="section-blend section-blend-top-reverse" aria-hidden="true"></div>
		<div class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-16 md:flex-row md:items-center">
			<div class="aspect-square w-full max-w-xs shrink-0 rounded border border-border bg-bg-card">
			</div>
			<div class="flex flex-col gap-4">
				<h2 class="text-2xl text-text">
					{/* TODO: review copy */}
					About
				</h2>
				<p class="max-w-xl text-text-muted">
					{/* TODO: review copy */}
					I'm Kostas, a developer based in Athens. I build sites that are fast, accessible, and easy
					to maintain — for Greek small businesses and international teams alike.
				</p>
				<a href="/about" class="text-sm text-primary hover:underline">
					{/* TODO: review copy */}
					More about me
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
	.section-alt {
		background-color: var(--bg-card);
	}

	.section-blend {
		position: absolute;
		left: 0;
		right: 0;
		top: -50px;
		height: 50px;
		pointer-events: none;
	}

	.section-blend-top {
		background: linear-gradient(to bottom, var(--bg), var(--bg-card));
	}

	.section-blend-top-reverse {
		background: linear-gradient(to bottom, var(--bg-card), var(--bg));
	}
</style>

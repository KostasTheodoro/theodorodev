---
import Layout from '@/layouts/Layout.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { getFeaturedProjects } from '@/lib/content';
import { availabilityStatus, availabilityCopy } from '@/lib/availability';

const featured = await getFeaturedProjects('en');
const { label: availabilityLabel, dotClass: availabilityDotClass } =
	availabilityCopy[availabilityStatus];
---

<Layout title="theodorodev — web developer, Athens">
	<section class="mx-auto flex max-w-5xl flex-col gap-6 px-6 py-24">
		<div class="flex items-center gap-2 self-start rounded-full border border-border px-3 py-1 text-xs text-text-muted">
			<span class={`h-2 w-2 rounded-full ${availabilityDotClass}`}></span>
			{availabilityLabel}
		</div>
		<p class="font-mono text-sm text-text-muted">
			{/* TODO: review copy */}
			const developer = "Kostas Theodoropoulos";
		</p>
		<h1 class="text-4xl leading-tight text-text sm:text-5xl">
			Websites that load instantly and bring customers.
		</h1>
		<p class="max-w-2xl text-text-muted">
			{/* TODO: review copy */}
			I design and build fast, focused websites for small businesses and teams who need results,
			not bloat.
		</p>
		<div class="flex flex-wrap gap-4">
			<a
				href="/projects"
				class="rounded bg-primary px-5 py-2.5 text-sm text-on-primary hover:opacity-90"
			>
				{/* TODO: review copy */}
				View projects
			</a>
			<a
				href="/contact"
				class="rounded border border-border px-5 py-2.5 text-sm text-text hover:border-primary"
			>
				{/* TODO: review copy */}
				Get in touch
			</a>
		</div>
	</section>

	<section class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-16">
		<h2 class="text-2xl text-text">
			{/* TODO: review copy */}
			Selected work
		</h2>
		<div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
			{featured.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	<section class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-16 md:flex-row md:items-center">
		<div class="aspect-square w-full max-w-xs shrink-0 rounded border border-border bg-bg-card">
		</div>
		<div class="flex flex-col gap-4">
			<h2 class="text-2xl text-text">
				{/* TODO: review copy */}
				About
			</h2>
			<p class="max-w-xl text-text-muted">
				{/* TODO: review copy */}
				I'm Kostas, a developer based in Athens. I build sites that are fast, accessible, and easy
				to maintain — for Greek small businesses and international teams alike.
			</p>
			<a href="/about" class="text-sm text-primary hover:underline">
				{/* TODO: review copy */}
				More about me
			</a>
		</div>
	</section>
</Layout>

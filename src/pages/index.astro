---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import PersonSchema from '@/components/PersonSchema.astro';
import OutlineButton from '@/components/OutlineButton.astro';
import { getFeaturedProjects } from '@/lib/content';

const featured = await getFeaturedProjects('en');
---

<Layout
	title="theodorodev — web developer, Athens"
	description="I design and build fast, focused websites for small businesses and teams who need results, not bloat."
>
	<PersonSchema />
	<Hero />

	<section class="section-alt relative">
		<div class="section-blend section-blend-top" aria-hidden="true"></div>
		<div class="mx-auto flex max-w-5xl flex-col gap-8 px-6 py-16">
			<h2 class="text-2xl text-text">My work</h2>
			<div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3">
				{featured.map((project) => <ProjectCard project={project} />)}
			</div>
			<div>
				<OutlineButton href="/projects">View all projects</OutlineButton>
			</div>
		</div>
	</section>

	<section class="relative isolate overflow-hidden">
		<div class="section-blend section-blend-top-reverse" aria-hidden="true"></div>
		<div class="about-glow" aria-hidden="true"></div>
		<div class="mx-auto max-w-5xl px-6 py-16">
			<div class="flex flex-col gap-4 rounded-lg border border-border bg-bg-card/50 p-8 sm:p-10">
				<p class="font-mono text-sm text-text-muted">// about</p>
				<h2 class="text-2xl text-text">About</h2>
				<p class="max-w-xl text-text-muted">
					I'm Kostas, a developer based in Athens. I specialize in the React ecosystem, and I'm
					always looking for new challenges and projects.
				</p>
				<div>
					<OutlineButton href="/about">More about me</OutlineButton>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	.section-alt {
		background-color: var(--bg-card);
	}

	.section-blend {
		position: absolute;
		left: 0;
		right: 0;
		top: -50px;
		height: 50px;
		pointer-events: none;
	}

	.section-blend-top {
		background: linear-gradient(to bottom, var(--bg), var(--bg-card));
	}

	.section-blend-top-reverse {
		background: linear-gradient(to bottom, var(--bg-card), var(--bg));
	}

	.about-glow {
		position: absolute;
		inset: 0;
		z-index: -1;
		pointer-events: none;
		background: radial-gradient(circle at 85% 15%, color-mix(in srgb, var(--petrol-mid) 14%, transparent) 0%, transparent 55%);
	}

	/* same reasoning as Hero's light-theme glow override: --petrol-mid reads muddy at
	   full strength against the light surface, so soften it */
	:global([data-theme='light']) .about-glow {
		background: radial-gradient(circle at 85% 15%, color-mix(in srgb, var(--petrol-mid) 8%, transparent) 0%, transparent 55%);
	}
</style>

---
interface Props {
	year: string;
	accent?: boolean;
}

const { year, accent = false } = Astro.props;
---

<div class="flex flex-col gap-2 sm:flex-row sm:gap-6">
	<div class="shrink-0 sm:w-20">
		<span class={`font-mono text-sm text-primary ${accent ? 'font-semibold' : ''}`}>{year}</span>
	</div>
	<div class="flex-1 text-text-muted [&_a]:text-primary [&_a]:underline [&_a:focus-visible]:outline-none [&_a:focus-visible]:ring-2 [&_a:focus-visible]:ring-primary [&_a:focus-visible]:ring-offset-2 [&_a:focus-visible]:ring-offset-bg [&_p]:leading-7">
		<slot />
	</div>
</div>

---
interface Props {
	year: string;
	accent?: boolean;
}

const { year, accent = false } = Astro.props;
---

<div class="flex flex-col gap-2 sm:flex-row sm:gap-6">
	<div class="shrink-0 sm:w-20">
		<span class={`font-mono text-sm text-primary ${accent ? 'font-semibold' : ''}`}>{year}</span>
	</div>
	<div class="flex-1 text-text-muted [&_p]:leading-7">
		<slot />
	</div>
</div>

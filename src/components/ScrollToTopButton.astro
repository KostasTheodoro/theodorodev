---
import { ArrowUp } from 'lucide-astro';
---

<button
	id="scroll-to-top"
	type="button"
	class="scroll-to-top fixed right-6 bottom-6 z-40 flex h-11 w-11 items-center justify-center rounded-full bg-primary text-on-primary shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
	aria-label="Scroll to top"
>
	<ArrowUp class="h-5 w-5" aria-hidden="true" />
</button>

<script is:inline>
	document.addEventListener('astro:page-load', () => {
		const button = document.getElementById('scroll-to-top');
		if (!button) return;

		const SHOW_THRESHOLD = 400;

		function onScroll() {
			button.classList.toggle('is-visible', window.scrollY > SHOW_THRESHOLD);
		}

		function onClick() {
			const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			window.scrollTo({ top: 0, behavior: prefersReducedMotion ? 'auto' : 'smooth' });
		}

		onScroll();
		window.addEventListener('scroll', onScroll, { passive: true });
		button.addEventListener('click', onClick);

		// document/window persist across Astro view transitions (only <body> children are
		// replaced), so these listeners must be torn down before each swap or they leak.
		document.addEventListener(
			'astro:before-swap',
			() => {
				window.removeEventListener('scroll', onScroll);
				button.removeEventListener('click', onClick);
			},
			{ once: true },
		);
	});
</script>

<style>
	.scroll-to-top {
		opacity: 0;
		transform: scale(0.9);
		pointer-events: none;
	}

	.scroll-to-top.is-visible {
		opacity: 1;
		transform: scale(1);
		pointer-events: auto;
	}

	.scroll-to-top.is-visible:hover {
		transform: scale(1.05);
	}

	.scroll-to-top.is-visible:active {
		transform: scale(0.97);
	}

	@media (prefers-reduced-motion: no-preference) {
		.scroll-to-top {
			transition:
				opacity 200ms ease,
				transform 200ms ease;
		}
	}
</style>

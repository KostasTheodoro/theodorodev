---
import { ArrowRight } from 'lucide-astro';

interface Props {
	href: string;
	arrow?: boolean;
}

const { href, arrow = false } = Astro.props;
---

<a
	href={href}
	class="inline-flex items-center gap-2 rounded border border-primary px-5 py-2.5 text-sm text-text hover:bg-primary/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
	<slot />
	{arrow && <ArrowRight class="h-4 w-4" aria-hidden="true" />}
</a>

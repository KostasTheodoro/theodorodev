---
interface Props {
	href: string;
}

const { href } = Astro.props;
---

<a
	href={href}
	class="outline-button inline-flex items-center gap-2 rounded-xl border border-primary px-5 py-2.5 text-sm text-text hover:scale-105 hover:bg-primary hover:text-on-primary active:scale-[0.97] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
>
	<slot />
</a>

<style>
	@media (prefers-reduced-motion: no-preference) {
		.outline-button {
			transition:
				transform 150ms ease,
				background-color 150ms ease,
				color 150ms ease;
		}
	}
</style>
